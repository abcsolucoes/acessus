# Copie este arquivo para .env (na raiz do repo) e preencha com os valores reais
# NUNCA commite o arquivo .env no git

# E-mail (Gmail App Password)
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx

# JWT — gere uma chave aleatória de pelo menos 32 caracteres
# Exemplo: openssl rand -base64 48
JWT_SECRET=troque-por-uma-chave-aleatoria-longa-aqui

# URL base do frontend (usada nos links enviados por e-mail)
BASE_URL=http://localhost:5500

# Origens permitidas pelo CORS (separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Caminho do executável do LibreOffice, usado pra converter contratos .docx em PDF.
# Em produção (Linux, depois do apt install) não precisa disso, o padrão "soffice" já resolve.
# No Windows, aponte pro soffice.exe — use "/" em vez de "\", esse arquivo é lido como .properties
# e barra invertida é caractere de escape ali (viraria caminho errado)
SOFFICE_PATH=C:/Program Files/LibreOffice/program/soffice.exe
